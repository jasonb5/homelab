should set single path:
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: common-test
        app.kubernetes.io/version: 1.16.0
        helm.sh/chart: common-test-0.1.0
      name: common-test
      namespace: NAMESPACE
    spec:
      replicas: 1
      selector:
        matchLabels:
          app.kubernetes.io/instance: RELEASE-NAME
          app.kubernetes.io/name: common-test
      template:
        metadata:
          labels:
            app.kubernetes.io/instance: RELEASE-NAME
            app.kubernetes.io/name: common-test
        spec:
          containers:
          - image: ubuntu:20.04
            name: common-test
            ports:
            - containerPort: 80
              name: http
  2: |
    apiVersion: v1
    kind: Service
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: common-test
        app.kubernetes.io/version: 1.16.0
        helm.sh/chart: common-test-0.1.0
      name: common-test-http
      namespace: NAMESPACE
    spec:
      ports:
      - name: http
        port: 80
        protocol: null
      selector:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/name: common-test
  3: |
    apiVersion: networking.k8s.io/v1
    kind: Ingress
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: common-test
        app.kubernetes.io/version: 1.16.0
        helm.sh/chart: common-test-0.1.0
      name: common-test-http
      namespace: NAMESPACE
    spec:
      rules:
      - http:
          paths:
          - backend:
              service:
                name: common-test-http
                port:
                  number: 80
            path: /
