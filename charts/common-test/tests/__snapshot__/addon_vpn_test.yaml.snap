should match snapshot:
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: common-test
        app.kubernetes.io/version: 1.16.0
        helm.sh/chart: common-test-0.1.0
      name: common-test
      namespace: NAMESPACE
    spec:
      replicas: 1
      selector:
        matchLabels:
          app.kubernetes.io/instance: RELEASE-NAME
          app.kubernetes.io/name: common-test
      template:
        metadata:
          labels:
            app.kubernetes.io/instance: RELEASE-NAME
            app.kubernetes.io/name: common-test
        spec:
          containers:
          - image: ubuntu:20.04
            name: common-test
            volumeMounts: null
          - image: dperson/openvpn-client:latest
            name: openvpn
            securityContext:
              capabilities:
                add:
                - NET_ADMIN
                - SYS_MODULE
            volumeMounts:
            - mountPath: /vpn/vpn.auth
              name: vpn-auth
              subPath: vpn.auth
            - mountPath: /vpn/vpn.conf
              name: vpn-config
              subPath: vpn.conf
          volumes:
          - name: vpn-auth
            secret:
              secretName: common-test-vpn
          - name: vpn-config
            secret:
              secretName: common-test-vpn
  2: |
    apiVersion: v1
    data:
      vpn.auth: dXNlcm5hbWUKcGFzc3dvcmQK
      vpn.conf: dnBuCg==
    kind: Secret
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: common-test
        app.kubernetes.io/version: 1.16.0
        helm.sh/chart: common-test-0.1.0
      name: common-test-vpn
      namespace: NAMESPACE
    type: Opaque
